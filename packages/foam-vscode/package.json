{
  "name": "foam-vscode",
  "displayName": "Foam",
  "description": "VS Code + Markdown + Wikilinks para suas anotações e base de conhecimento",
  "private": true,
  "repository": {
    "url": "https://github.com/foambubble/foam",
    "type": "git"
  },
  "homepage": "https://github.com/foambubble/foam",
  "version": "0.40.2",
  "license": "MIT",
  "publisher": "foam",
  "engines": {
    "vscode": "^1.110.0"
  },
  "icon": "assets/icon/FOAM_ICON_256.png",
  "categories": [
    "Other"
  ],
  "main": "./out/bundles/extension-node.js",
  "browser": "./out/bundles/extension-web.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Expressões não são permitidas em filtros."
    }
  },
  "contributes": {
    "chatParticipants": [
      {
        "id": "foam-vscode.sistema",
        "name": "sistema",
        "fullName": "Foam Sistema",
        "description": "Cria e consulta a estrutura de documentação do sistema (módulos, funções, páginas, backlog)",
        "isSticky": false
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "foam-explorer",
          "title": "Foam",
          "icon": "assets/icon/foam-icon.svg"
        }
      ]
    },
    "markdown.markdownItPlugins": true,
    "markdown.previewStyles": [
      "./static/preview/style.css"
    ],
    "markdown.previewScripts": [
      "./static/preview/block-anchor-scroll.js"
    ],
    "grammars": [
      {
        "path": "./syntaxes/injection.json",
        "scopeName": "foam.wikilink.injection",
        "injectTo": [
          "text.html.markdown"
        ]
      }
    ],
    "colors": [
      {
        "id": "foam.placeholder",
        "description": "Color of foam placeholders.",
        "defaults": {
          "dark": "editorWarning.foreground",
          "light": "editorWarning.foreground",
          "highContrast": "editorWarning.foreground"
        }
      }
    ],
    "views": {
      "foam-explorer": [
        {
          "id": "foam-vscode.quick-actions",
          "name": "Ações Rápidas",
          "icon": "$(home)",
          "contextualTitle": "Foam"
        },
        {
          "id": "foam-vscode.system-explorer",
          "name": "Sistema",
          "icon": "$(list-tree)",
          "contextualTitle": "Foam — Sistema"
        },
        {
          "id": "foam-vscode.ai-panel",
          "name": "Inteligência Artificial",
          "icon": "$(sparkle)",
          "contextualTitle": "Foam IA",
          "when": "config.foam.experimental.ai"
        },
        {
          "id": "foam-vscode.connections",
          "name": "Conexões",
          "icon": "$(references)",
          "contextualTitle": "Foam"
        },
        {
          "id": "foam-vscode.tags-explorer",
          "name": "Explorador de Tags",
          "icon": "$(tag)",
          "contextualTitle": "Foam"
        },
        {
          "id": "foam-vscode.notes-explorer",
          "name": "Notas",
          "icon": "$(notebook)",
          "contextualTitle": "Foam"
        },
        {
          "id": "foam-vscode.orphans",
          "name": "Notas Isoladas",
          "icon": "$(debug-gripper)",
          "contextualTitle": "Foam"
        },
        {
          "id": "foam-vscode.placeholders",
          "name": "Placeholders",
          "icon": "$(debug-disconnect)",
          "contextualTitle": "Foam"
        },
        {
          "when": "config.foam.experimental.ai",
          "id": "foam-vscode.related-notes",
          "name": "Notas Relacionadas (IA)",
          "icon": "$(sparkle)",
          "contextualTitle": "Foam"
        }
      ],
      "explorer": [
        {
          "id": "foam-vscode.connections",
          "name": "Conexões",
          "icon": "$(references)",
          "contextualTitle": "Foam"
        },
        {
          "id": "foam-vscode.tags-explorer",
          "name": "Explorador de Tags",
          "icon": "$(tag)",
          "contextualTitle": "Foam"
        },
        {
          "id": "foam-vscode.notes-explorer",
          "name": "Notas",
          "icon": "$(notebook)",
          "contextualTitle": "Foam"
        },
        {
          "id": "foam-vscode.orphans",
          "name": "Notas Isoladas",
          "icon": "$(debug-gripper)",
          "contextualTitle": "Foam"
        },
        {
          "id": "foam-vscode.placeholders",
          "name": "Placeholders",
          "icon": "$(debug-disconnect)",
          "contextualTitle": "Foam"
        },
        {
          "when": "config.foam.experimental.ai",
          "id": "foam-vscode.related-notes",
          "name": "Notas Relacionadas (IA)",
          "icon": "$(sparkle)",
          "contextualTitle": "Foam"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "foam-vscode.quick-actions",
        "contents": "## Foam — Gestão de Conhecimento\n\n[$(file-add) Nova Nota](command:foam-vscode.create-note)\n[$(calendar) Nota de Hoje](command:foam-vscode.open-daily-note)\n[$(graph) Mostrar Grafo](command:foam-vscode.show-graph)\n[$(search) Buscar por Tag](command:foam-vscode.search-tag)\n[$(random) Nota Aleatória](command:foam-vscode.open-random-note)\n[$(notebook) Nova Nota por Template](command:foam-vscode.create-note-from-template)"
      },
      {
        "view": "foam-vscode.system-explorer",
        "contents": "## Estrutura do Sistema\n\nNenhum item cadastrado ainda.\n\n[$(search) Lookup (Dendron-style)](command:foam-vscode.system-explorer.lookup)\n[$(add) Criar Item do Sistema](command:foam-vscode.system-explorer.create-item)\n[$(browser) Nova Página](command:foam-vscode.system-explorer.create-pagina)\n[$(package) Novo Módulo](command:foam-vscode.system-explorer.create-modulo)\n[$(symbol-method) Nova Função](command:foam-vscode.system-explorer.create-funcao)\n[$(tasklist) Novo Backlog](command:foam-vscode.system-explorer.create-backlog)\n[$(lightbulb) Nova Ideia](command:foam-vscode.system-explorer.create-ideia)"
      },
      {
        "view": "foam-vscode.ai-panel",
        "contents": "## Foam IA\n\n[$(sparkle) Abrir Prompt Workshop](command:foam-vscode.open-prompt-workshop)\n[$(references) Notas Similares](command:foam-vscode.show-similar-notes)\n[$(database) Construir Índice IA](command:foam-vscode.build-embeddings)\n[$(key) Configurar Chave OpenAI](command:foam-vscode.set-openai-key)",
        "when": "config.foam.experimental.ai"
      },
      {
        "view": "foam-vscode.tags-explorer",
        "contents": "Nenhuma tag encontrada. Notas que contêm tags aparecerão aqui. Você pode adicionar tags com uma hashtag (#tag) ou adicionando uma lista de tags no front matter (tags: tag1, tag2)."
      },
      {
        "view": "foam-vscode.connections",
        "contents": "Nenhum resultado para o recurso selecionado e o filtro atual."
      },
      {
        "view": "foam-vscode.orphans",
        "contents": "Nenhuma nota isolada encontrada. Notas sem backlinks nem links aparecerão aqui."
      },
      {
        "view": "foam-vscode.placeholders",
        "contents": "Nenhum placeholder encontrado para o recurso ou workspace selecionado."
      },
      {
        "view": "foam-vscode.related-notes",
        "contents": "Abra uma nota para ver notas relacionadas.",
        "when": "config.foam.experimental.ai && foam.relatedNotes.state == 'no-note'"
      },
      {
        "view": "foam-vscode.related-notes",
        "contents": "As notas ainda não foram analisadas.\n[Analisar Notas](command:foam-vscode.build-embeddings)\nAnalise suas notas para descobrir conteúdo similar.",
        "when": "config.foam.experimental.ai && foam.relatedNotes.state == 'no-embedding'"
      },
      {
        "view": "foam-vscode.related-notes",
        "contents": "Nenhuma nota similar encontrada para a nota atual.",
        "when": "config.foam.experimental.ai && foam.relatedNotes.state == 'ready'"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "foam-vscode.search-tag",
          "when": "view == foam-vscode.tags-explorer && viewItem == tag",
          "group": "inline",
          "icon": "$(search)"
        },
        {
          "command": "foam-vscode.rename-tag",
          "when": "view == foam-vscode.tags-explorer && viewItem == tag",
          "group": "inline",
          "icon": "$(edit)"
        }
      ],
      "editor/context": [
        {
          "command": "foam-vscode.rename-tag",
          "when": "editorTextFocus && resourceExtname == '.md'",
          "group": "foam",
          "title": "Rename Tag"
        }
      ],
      "view/title": [
        {
          "command": "foam-vscode.system-explorer.lookup",
          "when": "view == foam-vscode.system-explorer",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.system-explorer.create-item",
          "when": "view == foam-vscode.system-explorer",
          "group": "navigation",
          "icon": "$(add)"
        },
        {
          "command": "foam-vscode.views.connections.show:backlinks",
          "when": "view == foam-vscode.connections && foam-vscode.views.connections.show == 'all links'",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.connections.show:forward-links",
          "when": "view == foam-vscode.connections && foam-vscode.views.connections.show == 'backlinks'",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.connections.show:all-links",
          "when": "view == foam-vscode.connections && foam-vscode.views.connections.show == 'forward links'",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.orphans.group-by:folder",
          "when": "view == foam-vscode.orphans && foam-vscode.views.orphans.group-by == 'off'",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.orphans.group-by:off",
          "when": "view == foam-vscode.orphans && foam-vscode.views.orphans.group-by == 'folder'",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.tags-explorer.show:for-current-file",
          "when": "view == foam-vscode.tags-explorer && foam-vscode.views.tags-explorer.show == 'all'",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.tags-explorer.show:all",
          "when": "view == foam-vscode.tags-explorer && foam-vscode.views.tags-explorer.show == 'for-current-file'",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.tags-explorer.group-by:folder",
          "when": "view == foam-vscode.tags-explorer && foam-vscode.views.tags-explorer.group-by == 'off'",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.tags-explorer.group-by:off",
          "when": "view == foam-vscode.tags-explorer && foam-vscode.views.tags-explorer.group-by == 'folder'",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.tags-explorer.expand-all",
          "when": "view == foam-vscode.tags-explorer",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.placeholders.show:for-current-file",
          "when": "view == foam-vscode.placeholders && foam-vscode.views.placeholders.show == 'all'",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.placeholders.show:all",
          "when": "view == foam-vscode.placeholders && foam-vscode.views.placeholders.show == 'for-current-file'",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.placeholders.group-by:folder",
          "when": "view == foam-vscode.placeholders && foam-vscode.views.placeholders.group-by == 'off'",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.placeholders.group-by:off",
          "when": "view == foam-vscode.placeholders && foam-vscode.views.placeholders.group-by == 'folder'",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.placeholders.expand-all",
          "when": "view == foam-vscode.placeholders",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.notes-explorer.collapse-all",
          "when": "view == foam-vscode.notes-explorer && foam-vscode.views.notes-explorer.view-mode != 'flat'",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.notes-explorer.connections:toggle",
          "when": "view == foam-vscode.notes-explorer",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.notes-explorer.show:toggle",
          "when": "view == foam-vscode.notes-explorer",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.notes-explorer.view:toggle",
          "when": "view == foam-vscode.notes-explorer",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.notes-explorer.set-filter",
          "when": "view == foam-vscode.notes-explorer",
          "group": "navigation"
        },
        {
          "command": "foam-vscode.views.notes-explorer.clear-filter",
          "when": "view == foam-vscode.notes-explorer && foam-vscode.views.notes-explorer.filter-active",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "foam-vscode.create-note-from-default-template",
          "when": "false"
        },
        {
          "command": "foam-vscode.update-graph",
          "when": "false"
        },
        {
          "command": "foam-vscode.views.connections.show:all-links",
          "when": "false"
        },
        {
          "command": "foam-vscode.views.connections.show:backlinks",
          "when": "false"
        },
        {
          "command": "foam-vscode.views.connections.show:forward-links",
          "when": "false"
        },
        {
          "command": "foam-vscode.views.orphans.group-by:folder",
          "when": "false"
        },
        {
          "command": "foam-vscode.views.orphans.group-by:off",
          "when": "false"
        },
        {
          "command": "foam-vscode.views.tags-explorer.show:for-current-file",
          "when": "false"
        },
        {
          "command": "foam-vscode.views.tags-explorer.show:all",
          "when": "false"
        },
        {
          "command": "foam-vscode.views.tags-explorer.group-by:folder",
          "when": "false"
        },
        {
          "command": "foam-vscode.views.tags-explorer.group-by:off",
          "when": "false"
        },
        {
          "command": "foam-vscode.views.tags-explorer.expand-all",
          "when": "false"
        },
        {
          "command": "foam-vscode.views.placeholders.show:for-current-file",
          "when": "false"
        },
        {
          "command": "foam-vscode.views.placeholders.show:all",
          "when": "false"
        },
        {
          "command": "foam-vscode.views.placeholders.group-by:folder",
          "when": "false"
        },
        {
          "command": "foam-vscode.views.placeholders.group-by:off",
          "when": "false"
        },
        {
          "command": "foam-vscode.views.placeholders.expand-all",
          "when": "false"
        },
        {
          "command": "foam-vscode.open-resource",
          "when": "false"
        },
        {
          "command": "foam-vscode.completion-move-cursor",
          "when": "false"
        }
      ]
    },
    "commands": [
      {
        "command": "foam-vscode.show-whats-new",
        "title": "Foam: Ver Novidades"
      },
      {
        "command": "foam-vscode.system-explorer.create-item",
        "title": "Foam: Criar Item do Sistema",
        "icon": "$(add)"
      },
      {
        "command": "foam-vscode.system-explorer.lookup",
        "title": "Foam: Sistema Lookup"
      },
      {
        "command": "foam-vscode.system-explorer.create-pagina",
        "title": "Foam: Nova Página do Sistema"
      },
      {
        "command": "foam-vscode.system-explorer.create-modulo",
        "title": "Foam: Novo Módulo"
      },
      {
        "command": "foam-vscode.system-explorer.create-funcao",
        "title": "Foam: Nova Função / Feature"
      },
      {
        "command": "foam-vscode.system-explorer.create-observacao",
        "title": "Foam: Nova Observação"
      },
      {
        "command": "foam-vscode.system-explorer.create-backlog",
        "title": "Foam: Novo Item de Backlog"
      },
      {
        "command": "foam-vscode.system-explorer.create-ideia",
        "title": "Foam: Nova Ideia"
      },
      {
        "command": "foam-vscode.create-note",
        "title": "Foam: Criar Nova Nota"
      },
      {
        "command": "foam-vscode.clear-cache",
        "title": "Foam: Limpar Cache"
      },
      {
        "command": "foam-vscode.update-graph",
        "title": "Foam: Atualizar Grafo"
      },
      {
        "command": "foam-vscode.set-log-level",
        "title": "Foam: Definir Nível de Log"
      },
      {
        "command": "foam-vscode.show-graph",
        "title": "Foam: Mostrar Grafo"
      },
      {
        "command": "foam-vscode.update-wikilink-definitions",
        "title": "Foam: Atualizar Definições de Wikilink"
      },
      {
        "command": "foam-vscode.open-daily-note",
        "title": "Foam: Abrir Nota de Hoje"
      },
      {
        "command": "foam-vscode.open-daily-note-for-date",
        "title": "Foam: Abrir Nota Diária"
      },
      {
        "command": "foam-vscode.open-random-note",
        "title": "Foam: Abrir Nota Aleatória"
      },
      {
        "command": "foam-vscode.janitor",
        "title": "Foam: Executar Limpeza (Experimental)"
      },
      {
        "command": "foam-vscode.copy-without-brackets",
        "title": "Foam: Copiar para Área de Transferência sem Colchetes"
      },
      {
        "command": "foam-vscode.create-note-from-template",
        "title": "Foam: Criar Nova Nota a partir de Template"
      },
      {
        "command": "foam-vscode.create-note-from-default-template",
        "title": "Foam: Criar Nova Nota"
      },
      {
        "command": "foam-vscode.open-resource",
        "title": "Foam: Abrir Recurso"
      },
      {
        "command": "foam-vscode.convert-wikilink-to-mdlink",
        "title": "Foam: Converter Wikilink para Link Markdown"
      },
      {
        "command": "foam-vscode.convert-mdlink-to-wikilink",
        "title": "Foam: Converter Link Markdown para Wikilink"
      },
      {
        "command": "foam-vscode.search-tag",
        "title": "Foam: Buscar Tag",
        "icon": "$(search)"
      },
      {
        "command": "foam-vscode.rename-tag",
        "title": "Foam: Renomear Tag",
        "icon": "$(edit)"
      },
      {
        "command": "foam-vscode.show-similar-notes",
        "title": "Foam: Mostrar Notas Similares",
        "when": "config.foam.experimental.ai"
      },
      {
        "command": "foam-vscode.build-embeddings",
        "title": "Foam: Construir Índice de Embeddings",
        "when": "config.foam.experimental.ai"
      },
      {
        "command": "foam-vscode.open-prompt-workshop",
        "title": "Foam: Abrir Prompt Workshop"
      },
      {
        "command": "foam-vscode.set-openai-key",
        "title": "Foam: Configurar Chave OpenAI"
      },
      {
        "command": "foam-vscode.views.orphans.group-by:folder",
        "title": "Agrupar por Pasta",
        "icon": "$(list-tree)"
      },
      {
        "command": "foam-vscode.views.connections.show:backlinks",
        "title": "Mostrar Backlinks",
        "icon": "$(arrow-left)"
      },
      {
        "command": "foam-vscode.views.connections.show:forward-links",
        "title": "Mostrar Links",
        "icon": "$(arrow-right)"
      },
      {
        "command": "foam-vscode.views.connections.show:all-links",
        "title": "Mostrar Todos",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "foam-vscode.views.orphans.group-by:off",
        "title": "Lista plana",
        "icon": "$(list-flat)"
      },
      {
        "command": "foam-vscode.views.tags-explorer.show:for-current-file",
        "title": "Mostrar tags do arquivo atual",
        "icon": "$(file)"
      },
      {
        "command": "foam-vscode.views.tags-explorer.show:all",
        "title": "Mostrar tags do workspace",
        "icon": "$(files)"
      },
      {
        "command": "foam-vscode.views.tags-explorer.group-by:folder",
        "title": "Agrupar por Pasta",
        "icon": "$(list-tree)"
      },
      {
        "command": "foam-vscode.views.tags-explorer.group-by:off",
        "title": "Lista plana",
        "icon": "$(list-flat)"
      },
      {
        "command": "foam-vscode.views.tags-explorer.expand-all",
        "title": "Expandir tudo",
        "icon": "$(expand-all)"
      },
      {
        "command": "foam-vscode.views.tags-explorer.focus",
        "title": "Focar na tag",
        "icon": "$(symbol-number)"
      },
      {
        "command": "foam-vscode.views.placeholders.show:for-current-file",
        "title": "Mostrar placeholders do arquivo atual",
        "icon": "$(file)"
      },
      {
        "command": "foam-vscode.views.placeholders.show:all",
        "title": "Mostrar placeholders do workspace",
        "icon": "$(files)"
      },
      {
        "command": "foam-vscode.views.placeholders.group-by:folder",
        "title": "Agrupar por Pasta",
        "icon": "$(list-tree)"
      },
      {
        "command": "foam-vscode.views.placeholders.group-by:off",
        "title": "Lista plana",
        "icon": "$(list-flat)"
      },
      {
        "command": "foam-vscode.views.placeholders.expand-all",
        "title": "Expandir tudo",
        "icon": "$(expand-all)"
      },
      {
        "command": "foam-vscode.views.notes-explorer.show:toggle",
        "title": "Alternar: Mostrar Todos / Apenas Notas",
        "icon": "$(markdown)"
      },
      {
        "command": "foam-vscode.views.notes-explorer.collapse-all",
        "title": "Recolher tudo",
        "icon": "$(collapse-all)"
      },
      {
        "command": "foam-vscode.views.notes-explorer.set-filter",
        "title": "Filtrar Notas",
        "icon": "$(filter)"
      },
      {
        "command": "foam-vscode.views.notes-explorer.clear-filter",
        "title": "Limpar Filtro",
        "icon": "$(filter-filled)"
      },
      {
        "command": "foam-vscode.views.notes-explorer.connections:toggle",
        "title": "Alternar Conexões",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "foam-vscode.views.notes-explorer.view:toggle",
        "title": "Alternar: Hierarquia / Lista Plana",
        "icon": "$(list-tree)"
      },
      {
        "command": "foam-vscode.create-new-template",
        "title": "Foam: Criar Novo Template"
      },
      {
        "command": "foam-vscode.completion-move-cursor",
        "title": "Foam: Mover cursor após completion"
      }
    ],
    "configuration": {
      "title": "Foam",
      "properties": {
        "foam.supportedLanguages": {
          "type": "array",
          "default": [
            "markdown"
          ],
          "description": "Lista de linguagens a serem tratadas como documentos Markdown."
        },
        "foam.completion.label": {
          "type": "string",
          "default": "path",
          "description": "Define qual propriedade da nota usar como label para itens de completion",
          "enum": [
            "path",
            "title",
            "identifier"
          ],
          "enumDescriptions": [
            "Usar o caminho da nota",
            "Usar o título da nota",
            "Usar o identificador da nota"
          ]
        },
        "foam.completion.useAlias": {
          "type": "string",
          "default": "never",
          "description": "Especifica em quais casos usar um alias ao criar um wikilink",
          "enum": [
            "never",
            "whenPathDiffersFromTitle"
          ],
          "enumDescriptions": [
            "Nunca usar aliases em itens de completion",
            "Usar alias se o caminho do recurso for diferente do título"
          ]
        },
        "foam.completion.linkFormat": {
          "type": "string",
          "default": "wikilink",
          "description": "Controla o formato dos links completados",
          "enum": [
            "wikilink",
            "link"
          ],
          "enumDescriptions": [
            "Completar como wikilinks (ex.: [[nome-da-nota]])",
            "Completar como links markdown (ex.: [Nome da Nota](nome-da-nota.md))"
          ]
        },
        "foam.files.ignore": {
          "type": [
            "array"
          ],
          "default": [
            "**/.vscode/**/*",
            "**/_layouts/**/*",
            "**/_site/**/*",
            "**/node_modules/**/*"
          ],
          "description": "Especifica a lista de globs ignorados pelo Foam (não considerados ao criar o grafo). Para ignorar todo o conteúdo de uma pasta, use `<nomeDaPasta>/**/*`",
          "deprecationMessage": "Use 'foam.files.exclude'. Esta configuração será removida em uma versão futura."
        },
        "foam.files.exclude": {
          "type": [
            "array"
          ],
          "default": [],
          "description": "Especifica a lista de globs excluídos pelo Foam (não considerados ao criar o grafo). Para excluir todo o conteúdo de uma pasta, use `<nomeDaPasta>/**/*`. Esta configuração é combinada com 'foam.files.ignore' (depreciado) e 'files.exclude'."
        },
        "foam.files.include": {
          "type": [
            "array"
          ],
          "default": [
            "**/*"
          ],
          "description": "Especifica a lista de padrões glob para arquivos incluídos no Foam. Os arquivos devem corresponder a pelo menos um padrão de inclusão e não corresponder a nenhum padrão de exclusão. Use para limitar o Foam a diretórios específicos (ex.: [\"notes/**\"]) ou tipos de arquivo (ex.: [\"**/*.md\"]). Padrão: todos os arquivos."
        },
        "foam.files.attachmentExtensions": {
          "type": "string",
          "default": "pdf mp3 webm wav m4a mp4 avi mov rtf txt doc docx pages xls xlsx numbers ppt pptm pptx",
          "description": "Lista de extensões de arquivo separadas por espaço que serão tratadas como anexos"
        },
        "foam.files.notesExtensions": {
          "type": "string",
          "default": "",
          "description": "Lista de extensões de arquivo extras separadas por espaço que serão tratadas como notas de texto (ex.: 'mdx txt markdown')"
        },
        "foam.files.defaultNoteExtension": {
          "type": "string",
          "default": "md",
          "description": "A extensão padrão para novas notas"
        },
        "foam.templates.folder": {
          "type": "string",
          "default": ".foam/templates",
          "description": "A pasta onde o Foam procura templates de notas, relativa à raiz do workspace."
        },
        "foam.files.newNotePath": {
          "type": "string",
          "default": "root",
          "description": "Especifica onde criar uma nova nota. Pode ser sobrescrito pelo template ou argumentos do comando",
          "enum": [
            "root",
            "currentDir"
          ],
          "enumDescriptions": [
            "Usar a raiz do workspace",
            "Usar o diretório do arquivo no editor atual"
          ]
        },
        "foam.logging.level": {
          "type": "string",
          "default": "info",
          "enum": [
            "off",
            "debug",
            "info",
            "warn",
            "error"
          ]
        },
        "foam.edit.linkReferenceDefinitions": {
          "type": "string",
          "default": "off",
          "enum": [
            "withExtensions",
            "withoutExtensions",
            "off"
          ],
          "enumDescriptions": [
            "Incluir extensão nos caminhos de wikilinks",
            "Remover extensão nos caminhos de wikilinks",
            "Desabilitar geração de definições de wikilink"
          ]
        },
        "foam.links.directory.mode": {
          "type": "string",
          "default": "resolve",
          "description": "Controla como links para nomes de diretório (ex.: [[bar]] ou [label](bar)) são resolvidos. 'resolve' procura um arquivo index dentro do diretório (index.<ext> ou README.<ext>). 'disabled' restaura a resolução estrita apenas por arquivo.",
          "enum": [
            "resolve",
            "disabled"
          ],
          "enumDescriptions": [
            "Resolver links de diretório para um arquivo index (index.<ext> ou README.<ext>) dentro do diretório",
            "Desabilitar resolução de links de diretório; apenas correspondências exatas de arquivo são usadas"
          ]
        },
        "foam.links.sync.enable": {
          "description": "Atualiza automaticamente wikilinks quando uma nota é renomeada ou movida. Para links markdown padrão, habilite a configuração nativa do VS Code 'markdown.updateLinksOnFileMove.enabled'.",
          "type": "boolean",
          "default": true
        },
        "foam.links.hover.enable": {
          "description": "Habilitar exibição do conteúdo da nota ao passar o mouse sobre links",
          "type": "boolean",
          "default": true
        },
        "foam.dateLocale": {
          "type": "string",
          "default": "default",
          "description": "O locale usado para variáveis de data como FOAM_DATE_DAY_NAME e FOAM_DATE_MONTH_NAME. Use 'default' para o locale do sistema, ou uma tag BCP 47 (ex.: 'pt-BR', 'en-US')."
        },
        "foam.openDailyNote.onStartup": {
          "type": "boolean",
          "default": false
        },
        "foam.openDailyNote.fileExtension": {
          "deprecationMessage": "This setting is deprecated and will be removed in future versions. Please use the daily-note template: https://github.com/foambubble/foam/blob/fe0228bdcc647e85682670656b5f09203b1c2518/docs/user/features/daily-notes.md",
          "type": "string",
          "default": "md"
        },
        "foam.openDailyNote.filenameFormat": {
          "deprecationMessage": "This setting is deprecated and will be removed in future versions. Please use the daily-note template: https://github.com/foambubble/foam/blob/fe0228bdcc647e85682670656b5f09203b1c2518/docs/user/features/daily-notes.md",
          "type": "string",
          "default": "isoDate",
          "markdownDescription": "Specifies how the daily note filename is formatted. See the [dateformat docs](https://www.npmjs.com/package/dateformat) for valid formats"
        },
        "foam.openDailyNote.titleFormat": {
          "deprecationMessage": "This setting is deprecated and will be removed in future versions. Please use the daily-note template: https://github.com/foambubble/foam/blob/fe0228bdcc647e85682670656b5f09203b1c2518/docs/user/features/daily-notes.md",
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "markdownDescription": "Specifies how the daily note title is formatted. Will default to the filename format if set to null. See the [dateformat docs](https://www.npmjs.com/package/dateformat) for valid formats"
        },
        "foam.openDailyNote.directory": {
          "deprecationMessage": "This setting is deprecated and will be removed in future versions. Please use the daily-note template: https://github.com/foambubble/foam/blob/fe0228bdcc647e85682670656b5f09203b1c2518/docs/user/features/daily-notes.md",
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "The directory into which daily notes should be created. Defaults to the workspace root."
        },
        "foam.orphans.exclude": {
          "type": [
            "array"
          ],
          "default": [],
          "markdownDescription": "Specifies the list of glob patterns that will be excluded from the orphans report. To ignore the all the content of a given folder, use `**<folderName>/**/*`"
        },
        "foam.placeholders.exclude": {
          "type": [
            "array"
          ],
          "default": [],
          "markdownDescription": "Specifies the list of glob patterns that will be excluded from the placeholders report. To ignore the all the content of a given folder, use `**<folderName>/**/*`"
        },
        "foam.dateSnippets.afterCompletion": {
          "type": "string",
          "default": "createNote",
          "enum": [
            "noop",
            "createNote",
            "navigateToNote"
          ],
          "enumDescriptions": [
            "Nada acontece após selecionar o item de completion",
            "A nota é criada seguindo as configurações de nota diária se não existir, mas sem navegação",
            "Navega para a nota, criando-a seguindo as configurações de nota diária se não existir"
          ],
          "description": "Se deve navegar para a nota diária alvo quando um snippet de nota diária é selecionado."
        },
        "foam.preview.embedNoteType": {
          "when": "config.foam.experimental.ai",
          "type": "string",
          "default": "full-card",
          "enum": [
            "full-inline",
            "full-card",
            "content-inline",
            "content-card"
          ],
          "enumDescriptions": [
            "Include the section with title and style inline",
            "Include the section with title and style it within a container",
            "Include the section without title and style inline",
            "Include the section without title and style it within a container"
          ]
        },
        "foam.graph.titleMaxLength": {
          "type": "number",
          "default": 24,
          "description": "O tamanho máximo do título antes de ser abreviado. Defina 0 ou menos para desabilitar."
        },
        "foam.graph.style": {
          "type": "object",
          "description": "Configurações personalizadas de estilo do grafo. Um exemplo está disponível na documentação.",
          "default": {}
        },
        "foam.graph.views": {
          "type": "array",
          "default": [],
          "description": "Views de grafo com nome. Uma view chamada \"Default\" é aplicada automaticamente quando o grafo abre sem argumentos. Outras views podem ser abertas via atalhos passando { \"view\": \"<nome>\" } como argumento do comando.",
          "items": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Nome de exibição. Use \"Default\" para aplicar esta view sempre que o grafo abrir sem argumentos."
              },
              "colorBy": {
                "type": "string",
                "enum": [
                  "none",
                  "directory",
                  "type"
                ],
                "description": "Estratégia padrão de coloração de nós."
              },
              "groups": {
                "type": "array",
                "description": "Regras de grupo personalizadas para coloração e visibilidade."
              },
              "show": {
                "type": "object",
                "description": "Substituições de visibilidade e cor para tipos nativos: tag, attachment, image, placeholder. Ex.: { \"tag\": { \"enabled\": false }, \"placeholder\": { \"color\": \"#ff0000\" } }"
              },
              "background": {
                "type": "string"
              },
              "fontSize": {
                "type": "number"
              },
              "fontFamily": {
                "type": "string"
              },
              "lineColor": {
                "type": "string"
              }
            }
          }
        },
        "foam.graph.onStartup": {
          "type": "boolean",
          "default": false,
          "description": "Se deve abrir o grafo na inicialização."
        },
        "foam.graph.navigateToPreview": {
          "type": "boolean",
          "default": false,
          "description": "Ao clicar em um nó no grafo, abrir a prévia markdown em vez do editor fonte."
        },
        "foam.experimental.ai": {
          "type": "boolean",
          "default": false,
          "description": "Habilita funcionalidades experimentais de IA (embeddings, notas relacionadas, Prompt Workshop). Requer Ollama rodando localmente ou chave OpenAI configurada."
        },
        "foam.ai.textGeneration.provider": {
          "type": "string",
          "default": "ollama",
          "description": "Provedor de geração de texto para o Prompt Workshop.",
          "enum": [
            "ollama",
            "openai"
          ],
          "enumDescriptions": [
            "Usar Ollama local para geração de texto",
            "Usar a API OpenAI (requer chave configurada)"
          ]
        },
        "foam.ai.textGeneration.ollama.url": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "URL base do servidor Ollama para geração de texto."
        },
        "foam.ai.textGeneration.ollama.model": {
          "type": "string",
          "default": "llama3",
          "description": "Modelo Ollama a usar para geração de texto no Prompt Workshop."
        },
        "foam.ai.textGeneration.openai.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "Modelo OpenAI a usar para geração de texto no Prompt Workshop."
        }
      }
    },
    "keybindings": [
      {
        "command": "foam-vscode.open-daily-note",
        "key": "alt+d"
      },
      {
        "command": "foam-vscode.open-daily-note-for-date",
        "key": "alt+h"
      }
    ]
  },
  "scripts": {
    "build:node": "node esbuild.js --platform=node",
    "build:web": "node esbuild.js --platform=web",
    "build:webview": "yarn workspace @foam/graph-view build",
    "build": "yarn build:node && yarn build:web",
    "vscode:prepublish": "yarn clean && yarn build:node --production && yarn build:web --production",
    "compile": "tsc -p ./",
    "test-reset-workspace": "rimraf .test-workspace && node -e \"const fs=require('fs'); fs.mkdirSync('.test-workspace',{recursive:true}); fs.writeFileSync('.test-workspace/.keep','');\"",
    "test-setup": "yarn compile && yarn build && yarn test-reset-workspace",
    "test": "yarn test:unit && yarn test:e2e",
    "test:unit": "yarn test-reset-workspace && vitest run",
    "test:unit-without-specs": "yarn test-reset-workspace && cross-env EXCLUDE_SPECS=true vitest run",
    "test:e2e": "yarn test-setup && node ./out/test/run-tests.js --e2e",
    "lint": "oxlint src",
    "clean": "rimraf out",
    "watch": "nodemon --watch 'src/**/*.ts' --watch '../foam-core/src/**/*.ts' --watch '../foam-graph/src/**/*.ts' --exec 'yarn build' --ext ts",
    "vscode:start-debugging": "yarn clean && yarn watch",
    "package-extension": "npx @vscode/vsce@3.6.0 package --yarn",
    "install-extension": "code --install-extension ./foam-vscode-$npm_package_version.vsix",
    "open-in-browser": "vscode-test-web --quality=stable --browser=chromium --extensionDevelopmentPath=. ",
    "publish-extension-openvsx": "npx ovsx publish foam-vscode-$npm_package_version.vsix -p $OPENVSX_TOKEN",
    "publish-extension-vscode": "npx vsce publish --packagePath foam-vscode-$npm_package_version.vsix",
    "publish-extension": "yarn publish-extension-vscode && yarn publish-extension-openvsx"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/markdown-it": "^12.0.1",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^18.0.0",
    "@types/picomatch": "^2.2.1",
    "@types/remove-markdown": "^0.3.4",
    "@types/vscode": "^1.110.0",
    "@vscode/test-web": "^0.0.80",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.0",
    "esbuild-plugin-polyfill-node": "^0.3.0",
    "markdown-it": "^12.0.4",
    "micromatch": "^4.0.8",
    "nodemon": "^3.1.14",
    "oxlint": "^1.57.0",
    "rimraf": "^3.0.2",
    "tslib": "^2.8.1",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0",
    "vscode-test": "^1.3.0",
    "wait-for-expect": "^3.0.2"
  },
  "dependencies": {
    "@foam/core": "^0.40.2",
    "@foam/graph-view": "^0.40.0",
    "dayjs": "^1.11.13",
    "detect-newline": "^3.1.0",
    "github-slugger": "^1.4.0",
    "gray-matter": "^4.0.2",
    "js-sha1": "^0.7.0",
    "lodash": "^4.17.21",
    "lru-cache": "^11.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-regex": "^0.2.0",
    "mnemonist": "^0.39.8",
    "path-browserify": "^1.0.1",
    "remark-frontmatter": "^2.0.0",
    "remark-parse": "^8.0.2",
    "remark-wiki-link": "^0.0.4",
    "title-case": "^3.0.2",
    "unified": "^9.0.0",
    "unist-util-visit": "^2.0.2",
    "yaml": "^2.2.2"
  },
  "__metadata": {
    "id": "b85c6625-454b-4b61-8a22-c42f3d0f2e1e",
